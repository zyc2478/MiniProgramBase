<view class="tab-bar">
  <view class="tab-bar-border"></view>
  <view wx:for="{{list}}" wx:key="index" class="tab-bar-item {{index === 2 ? 'special-item' : ''}}" data-path="{{item.pagePath}}" data-index="{{index}}" bindtap="switchTab">
    <block wx:if="{{index === 2}}">
      <view class="special-btn">
        <text class="special-text">会员卡</text>
      </view>
    </block>
    <block wx:else>
      <view class="tab-icon">{{item.iconPath}}</view>
      <view class="tab-text" style="color: {{selected === index ? selectedColor : color}}">{{item.text}}</view>
    </block>
  </view>
</view>
