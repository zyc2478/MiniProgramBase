<view class="container">
  <!-- 顶部搜索栏 -->
  <view class="header-search">
    <view class="search-bar">
      <icon type="search" size="14"></icon>
      <text class="search-placeholder">搜索美味餐食...</text>
    </view>
  </view>

  <scroll-view scroll-y class="main-content">
    <!-- 轮播图 -->
    <swiper class="banner-swiper" indicator-dots autoplay circular interval="3000">
      <swiper-item>
        <image src="https://images.unsplash.com/photo-1594212699903-ec8a3eca50f5?w=800" mode="aspectFill"></image>
      </swiper-item>
      <swiper-item>
        <image src="https://images.unsplash.com/photo-1550547660-d9450f859349?w=800" mode="aspectFill"></image>
      </swiper-item>
    </swiper>

    <!-- 快捷功能区 -->
    <view class="quick-actions">
      <view class="action-item" bindtap="goToMenu">
        <view class="action-icon order-icon">🛵</view>
        <view class="action-text">外卖下单</view>
        <view class="action-desc">准时必达</view>
      </view>
      <view class="action-item" bindtap="goToMenu">
        <view class="action-icon pickup-icon">🥡</view>
        <view class="action-text">到店自取</view>
        <view class="action-desc">无需排队</view>
      </view>
    </view>

    <!-- 优惠券/会员区 -->
    <view class="member-card">
      <view class="member-info">
        <view class="member-title">欢迎回来，美食达人</view>
        <view class="member-points">积分：1250 | 优惠券：3张</view>
      </view>
      <view class="member-btn">去领券</view>
    </view>

    <!-- 精选货架 (Featured Items) -->
    <view class="section-header">
      <text class="section-title">今日精选</text>
      <text class="section-more" bindtap="goToMenu">查看全部 ></text>
    </view>
    
    <view class="featured-shelf">
      <view class="shelf-item" wx:for="{{featuredFoods}}" wx:key="id" bindtap="goToMenu">
        <image src="{{item.image}}" mode="aspectFill" class="shelf-img"></image>
        <view class="shelf-info">
          <view class="shelf-name">{{item.name}}</view>
          <view class="shelf-bottom">
            <view class="shelf-price">￥{{item.price}}</view>
            <view class="shelf-add">+</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 底部垫片 -->
    <view class="footer-spacer"></view>
  </scroll-view>
</view>
