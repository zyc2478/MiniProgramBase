page {
  background-color: #f8f8f8;
  height: 100%;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100%;
}

/* 顶部搜索 */
.header-search {
  padding: 20rpx 30rpx;
  background-color: #ff4d4f;
}

.search-bar {
  background-color: #fff;
  height: 72rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
}

.search-placeholder {
  font-size: 26rpx;
  color: #999;
  margin-left: 15rpx;
}

.main-content {
  flex: 1;
  overflow: hidden;
}

/* 轮播图 */
.banner-swiper {
  height: 380rpx;
  margin-top: -1rpx; /* 消除间隙 */
}

.banner-swiper image {
  width: 100%;
  height: 100%;
}

/* 快捷操作 */
.quick-actions {
  display: flex;
  padding: 30rpx;
  gap: 20rpx;
  margin-top: -40rpx;
  position: relative;
  z-index: 10;
}

.action-item {
  flex: 1;
  background-color: #fff;
  padding: 40rpx 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-icon {
  font-size: 60rpx;
  margin-bottom: 20rpx;
}

.action-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.action-desc {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 会员卡 */
.member-card {
  margin: 0 30rpx 40rpx;
  background: linear-gradient(135deg, #1a1a1a, #333);
  padding: 40rpx;
  border-radius: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  color: #fff;
}

.member-title {
  font-size: 30rpx;
  font-weight: 500;
}

.member-points {
  font-size: 24rpx;
  color: #ccc;
  margin-top: 10rpx;
}

.member-btn {
  background-color: #ffc53d;
  color: #1a1a1a;
  padding: 12rpx 30rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: bold;
}

/* 货架区 */
.section-header {
  padding: 0 30rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.section-more {
  font-size: 26rpx;
  color: #999;
}

.featured-shelf {
  display: flex;
  flex-wrap: wrap;
  padding: 0 15rpx;
}

.shelf-item {
  width: 50%;
  padding: 15rpx;
  box-sizing: border-box;
}

.shelf-img {
  width: 100%;
  height: 320rpx;
  border-radius: 16rpx;
  background-color: #eee;
}

.shelf-info {
  background-color: #fff;
  padding: 20rpx;
  border-bottom-left-radius: 16rpx;
  border-bottom-right-radius: 16rpx;
  margin-top: -10rpx;
}

.shelf-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.shelf-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.shelf-price {
  font-size: 32rpx;
  color: #ff4d4f;
  font-weight: bold;
}

.shelf-add {
  width: 44rpx;
  height: 44rpx;
  background-color: #ff4d4f;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.footer-spacer {
  height: 60rpx;
}
