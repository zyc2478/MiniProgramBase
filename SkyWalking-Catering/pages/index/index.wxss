page {
  background-color: #f8f8f8;
  height: 100%;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100%;
}

/* 顶部搜索 */
.header-search {
  padding: 20rpx 30rpx 30rpx;
  background-color: #ff4d4f;
}

.shop-name {
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  text-align: center;
}

.search-bar {
  background-color: #fff;
  height: 64rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
}

.search-placeholder {
  font-size: 26rpx;
  color: #999;
  margin-left: 15rpx;
}

.main-content {
  flex: 1;
  overflow: hidden;
}

/* 轮播图 */
.banner-swiper {
  height: 320rpx;
  margin-top: -1rpx;
}

.banner-swiper image {
  width: 100%;
  height: 100%;
}

/* 快捷操作 */
.quick-actions {
  display: flex;
  padding: 30rpx;
  gap: 20rpx;
  margin-top: -60rpx;
  position: relative;
  z-index: 10;
}

.action-item {
  flex: 1;
  background-color: #fff;
  padding: 20rpx 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.action-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.action-desc {
  font-size: 20rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 会员卡 */
.member-card {
  margin: 0 30rpx 20rpx;
  background: linear-gradient(135deg, #1a1a1a, #333);
  padding: 24rpx 30rpx;
  border-radius: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  color: #fff;
}

.member-title {
  font-size: 30rpx;
  font-weight: 500;
}

.member-points {
  font-size: 24rpx;
  color: #ccc;
  margin-top: 10rpx;
}

.member-btn {
  background-color: #ffc53d;
  color: #1a1a1a;
  padding: 12rpx 30rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: bold;
}

/* 广告位样式 */
.promo-banner {
  margin: 0 30rpx 30rpx;
  background: linear-gradient(90deg, #ff4d4f, #ff7875);
  border-radius: 16rpx;
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(255, 77, 79, 0.2);
}

.promo-tag {
  font-size: 20rpx;
  background: rgba(255, 255, 255, 0.2);
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  display: inline-block;
  margin-bottom: 10rpx;
}

.promo-title {
  font-size: 32rpx;
  font-weight: bold;
}

.promo-subtitle {
  font-size: 24rpx;
  opacity: 0.9;
}

.promo-btn {
  background: #fff;
  color: #ff4d4f;
  padding: 12rpx 30rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.recharge-banner {
  margin: 0 30rpx 40rpx;
  height: 180rpx;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.1);
}

.recharge-bg {
  width: 100%;
  height: 100%;
}

.recharge-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.3);
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding-left: 40rpx;
  color: #fff;
}

.recharge-title {
  font-size: 40rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
}

.recharge-desc {
  font-size: 24rpx;
  margin-top: 10rpx;
  opacity: 0.9;
}

/* 货架区 */
.section-header {
  padding: 0 30rpx 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-more {
  font-size: 24rpx;
  color: #999;
}

.featured-shelf {
  display: flex;
  flex-wrap: wrap;
  padding: 0 15rpx;
}

.shelf-item {
  width: 50%;
  padding: 15rpx;
  box-sizing: border-box;
}

.shelf-img {
  width: 100%;
  height: 280rpx;
  border-top-left-radius: 16rpx;
  border-top-right-radius: 16rpx;
  background-color: #eee;
}

.shelf-info {
  background-color: #fff;
  padding: 16rpx;
  border-bottom-left-radius: 16rpx;
  border-bottom-right-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
}

.shelf-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 12rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.shelf-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.shelf-price {
  font-size: 30rpx;
  color: #ff4d4f;
  font-weight: bold;
}

.shelf-add {
  width: 40rpx;
  height: 40rpx;
  background-color: #ff4d4f;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.footer-spacer {
  height: 180rpx;
}

