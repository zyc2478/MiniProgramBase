page {
  height: 100%;
  background-color: #fff;
}

.menu-container {
  display: flex;
  height: 100%;
  overflow: hidden;
}

/* 左侧分类栏 */
.category-sidebar {
  width: 160rpx;
  height: 100%;
  background-color: #f7f7f7;
}

.category-item {
  height: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
}

.category-item.active {
  background-color: #fff;
  border-left: 6rpx solid #ff4d4f;
}

.cat-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.cat-name {
  font-size: 24rpx;
  color: #666;
}

.category-item.active .cat-name {
  color: #333;
  font-weight: bold;
}

/* 右侧货架 */
.product-shelf {
  flex: 1;
  height: 100%;
  padding: 0 24rpx;
}

.shelf-title {
  padding: 30rpx 0 20rpx;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.product-card {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.product-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background-color: #f5f5f5;
  margin-right: 20rpx;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.product-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.product-desc {
  font-size: 22rpx;
  color: #999;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin: 10rpx 0;
}

.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.product-price {
  color: #ff4d4f;
  display: flex;
  align-items: baseline;
}

.unit { font-size: 22rpx; }
.value { font-size: 36rpx; font-weight: bold; }
.original { 
  font-size: 22rpx; 
  color: #999; 
  text-decoration: line-through; 
  margin-left: 10rpx; 
}

/* 计数器 */
.counter {
  display: flex;
  align-items: center;
}

.btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.minus {
  border: 2rpx solid #ffccc7;
  color: #ff4d4f;
  background-color: #fff1f0;
}

.plus {
  background-color: #ff4d4f;
  color: #fff;
}

.num {
  width: 60rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333;
}

.shelf-spacer {
  height: 180rpx;
}

/* 购物车条 */
.cart-bar {
  position: fixed;
  bottom: 40rpx;
  left: 30rpx;
  right: 30rpx;
  height: 100rpx;
  background-color: #1a1a1a;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  z-index: 100;
  transition: all 0.3s;
  padding-left: 110rpx;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.2);
}

.cart-icon-box {
  position: absolute;
  left: 0;
  bottom: 0;
  width: 100rpx;
  height: 100rpx;
  background-color: #ff4d4f;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 0;
  transform: translateY(-10rpx);
}

.cart-icon { font-size: 50rpx; }

.badge {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  background-color: #ffc53d;
  color: #1a1a1a;
  font-size: 20rpx;
  font-weight: bold;
  min-width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
  border: 2rpx solid #1a1a1a;
}

.cart-info { flex: 1; }
.total-price { color: #fff; font-size: 36rpx; font-weight: bold; }
.discount-tip { color: #999; font-size: 20rpx; }
.empty-tip { color: #999; font-size: 28rpx; }

.checkout-btn {
  width: 180rpx;
  height: 100%;
  background-color: #333;
  color: #999;
  font-size: 28rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  border-top-right-radius: 50rpx;
  border-bottom-right-radius: 50rpx;
}

.checkout-btn.enabled {
  background-color: #ff4d4f;
  color: #fff;
}

/* 购物车详情弹窗 */
.cart-detail-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0,0,0,0.5);
  z-index: 90;
}

.cart-detail-popup {
  position: fixed;
  bottom: 140rpx;
  left: 0;
  right: 0;
  background-color: #fff;
  border-top-left-radius: 32rpx;
  border-top-right-radius: 32rpx;
  z-index: 95;
  padding-bottom: 20rpx;
}

.popup-header {
  padding: 30rpx;
  background-color: #f8f8f8;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  color: #666;
  border-top-left-radius: 32rpx;
  border-top-right-radius: 32rpx;
}

.clear-cart { color: #999; }

.popup-list {
  max-height: 500rpx;
  padding: 0 30rpx;
}

.popup-item {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.item-name { flex: 1; font-size: 30rpx; color: #333; }
.item-price { margin: 0 30rpx; font-size: 30rpx; font-weight: bold; color: #ff4d4f; }
