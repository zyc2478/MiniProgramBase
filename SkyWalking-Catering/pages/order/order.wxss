.page {
  padding: 30rpx;
  background-color: #f8f8f8;
  min-height: 100vh;
}

.status-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.05);
  margin-bottom: 40rpx;
}

.status-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 40rpx;
}

.order-no-box {
  text-align: center;
  margin-bottom: 40rpx;
}

.order-no-box .label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.order-no-box .number {
  font-size: 80rpx;
  font-weight: bold;
  color: #ff4d4f;
  letter-spacing: 4rpx;
}

.progress-bar {
  width: 100%;
  height: 8rpx;
  background: #eee;
  border-radius: 4rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.progress-inner {
  height: 100%;
  background: #ff4d4f;
  width: 60%;
}

.progress-inner.active {
  animation: progress 2s infinite linear;
  background: linear-gradient(90deg, #ff4d4f 0%, #ff7875 50%, #ff4d4f 100%);
  background-size: 200% 100%;
}

@keyframes progress {
  0% { background-position: 200% 0; }
  100% { background-position: 0 0; }
}

.status-tips {
  font-size: 24rpx;
  color: #999;
}

.empty-order {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 40rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.weui-cells__title {
  padding-left: 0;
}

.weui-cells {
  border-radius: 16rpx;
  overflow: hidden;
}
